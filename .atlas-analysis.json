  "projectType": "sdk-library",
  "projectName": "RaTeX",
  "projectDescription": "A KaTeX-compatible LaTeX math rendering engine written in pure Rust, with native bindings for iOS, Android, Flutter, React Native, Web (WASM), and server-side PNG/SVG output.",
