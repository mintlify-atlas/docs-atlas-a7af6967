  "keyFeatures": [
    "Pure Rust LaTeX math rendering engine with ~99% KaTeX syntax coverage",
    "No JavaScript, no WebView, no DOM — fully native on every platform",
    "One Rust core → iOS, Android, Flutter, React Native, Web (WASM), PNG, SVG",
    "Full mhchem support for chemistry notation via \\ce and \\pu",
    "C ABI for native platforms + WASM for browser environments",
    "Server-side PNG rasterization via tiny-skia",
    "Self-contained SVG export with embedded glyph outlines",
    "Thread-safe, predictable memory, offline-capable"
  ],
  "publicApiSurface": [
    "ratex_parse_and_layout(latex: *const c_char) -> *mut c_char  [C ABI]",
    "ratex_free_display_list(json: *mut c_char)  [C ABI]",
    "ratex_get_last_error() -> *const c_char  [C ABI]",
    "renderLatex(latex: string) -> string  [WASM]",
    "renderLatexToCanvas(latex, canvas, options)  [WASM / TypeScript]",
    "initRatex() -> Promise<void>  [WASM]",
    "<ratex-formula> Web Component (latex, font-size, padding, background-color attributes)",
    "RaTeXView (iOS UIKit / Android XML / React Native / Flutter widget)",
    "RaTeXFormula (iOS SwiftUI)",
    "RaTeXWidget (Flutter)",
    "RaTeXEngine.shared.parse() (iOS), RaTeXEngine.parse() (Android), RaTeXEngine.instance.parseAndLayout() (Flutter)",
    "RaTeXRenderer.draw() (iOS/Android)",
    "RaTeXSpan.create() (Android inline)",
    "InlineTeX component (React Native)",
    "DisplayList, DisplayItem, Color, MathStyle, PathCommand (Rust types)",
    "render_to_svg(list, opts: SvgOptions) -> String  [ratex-svg]"
  ]
